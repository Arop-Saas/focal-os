# ================================
# FOCAL OS — Environment Variables
# ================================
# Copy this file to .env.local and fill in your values

# ─── Database ───────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Focal OS"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create these in your Stripe dashboard
STRIPE_STARTER_PRICE_ID="price_..."   # $49/mo
STRIPE_PRO_PRICE_ID="price_..."       # $149/mo
STRIPE_ENTERPRISE_PRICE_ID="price_..." # $399/mo

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Maps JavaScript + Distance Matrix
GOOGLE_MAPS_API_KEY="AIza..."
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIza..."

# ─── Storage (optional — Supabase Storage is used by default) ────────────────
# Only needed if using Cloudflare R2 instead of Supabase Storage
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_URL=""

# ─── Auth Secrets ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
